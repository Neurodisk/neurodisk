# ============================================================
# NEURODISK — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter le fichier .env (déjà dans .gitignore).
#
# Sur Netlify : Site settings > Environment variables
# ============================================================

# Supabase — trouvées dans : Project Settings > API
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=VOTRE_ANON_KEY_PUBLIQUE

# Bunny.net — trouvé dans : Stream > Votre librairie > Embed
BUNNY_LIBRARY_ID=VOTRE_LIBRARY_ID
